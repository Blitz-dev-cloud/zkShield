# Shared signing secret between gateway and relay.
# Must be a long random value in production.
ZKSHIELD_FORWARD_SIGNING_KEY=replace-with-64-plus-char-random-secret

# Gateway runtime settings
ZKSHIELD_RELAY_URL=http://relay:5100/forward
ZKSHIELD_REDIS_URL=redis://redis:6379/0
ZKSHIELD_SESSION_TTL_SECONDS=3600
ZKSHIELD_NONCE_TTL_SECONDS=3600
ZKSHIELD_MAX_CLOCK_SKEW_SECONDS=30

# Relay runtime settings
ZKSHIELD_FORWARD_TTL_SECONDS=30
# Explicit allowlist only. No wildcard.
ZKSHIELD_RELAY_ALLOWED_HOSTS=api.internal.example.com,receiver.internal.example.com

# Frontend server-side workflow defaults
ZKSHIELD_GATEWAY_AUTH_URL=http://gateway:5001/auth
ZKSHIELD_GATEWAY_PACKET_URL=http://gateway:5001/packet
ZKSHIELD_GATEWAY_HEALTH_URL=http://gateway:5001/health
